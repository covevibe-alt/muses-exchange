# Secrets & credentials — NEVER commit
.env
.env.*
!.env.example
*.key
*.pem
.spotify-token.json

# Internal / non-shipping material
_internal/
*.command

# Python
__pycache__/
*.pyc
*.pyo

# Note on app/listener-ratios.json: this file IS tracked. The
# calibrate-ratios GitHub Actions workflow (calibrate-ratios.yml) is the
# only thing that should commit it — daily kworb scrape, 4× per day. If
# you find yourself running `app/calibrate-ratios.py` locally and it
# shows up as modified, just don't stage it; let the bot keep it canonical.

# Node
node_modules/

# OS & editor junk
.DS_Store
Thumbs.db
.fuse_hidden*
.~lock*
*.swp
.idea/
.vscode/

# Logs
*.log
