<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Muses Exchange Blog — Field Notes",
  "description": "Field notes from the team building a stock market for artists.",
  "url": "https://muses.exchange/blog",
